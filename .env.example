# Copy to .env (gitignored) and fill in. Secrets are read from the environment
# only — never commit real values.

# --- Engine (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Platform gateway ---
WB_DB_PATH=./wb.db                 # SQLite path for local dev; use Postgres in prod
WB_BASE_URL=http://localhost:8000  # public origin: drives secure cookies + OAuth redirects

# --- Admin / owner accounts (uncapped, never billed) ---
# Comma-separated emails that bypass every plan cap. Defaults to the owner;
# override to change or extend the list.
WB_ADMIN_EMAILS=vmahajans@yahoo.com

# --- Email (optional; password-reset delivery) ---
# Without WB_SMTP_HOST the app uses a console mailer (prints reset links, no
# network) — fine for local dev. Set these for real delivery.
WB_SMTP_HOST=
WB_SMTP_PORT=587
WB_SMTP_USER=
WB_SMTP_PASSWORD=
WB_SMTP_TLS=1
WB_MAIL_FROM=no-reply@localhost

# --- OAuth (optional; enables Google/Microsoft sign-in) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Stripe (optional; real billing — else the local provider is used) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# --- Plagiarism / AI detection (Feature 1 + 2; ADR-001) ---
# Vendor: Originality.ai (bundles plagiarism + AI detection under one key).
# Without this key, /v1/scan returns a structured `feature_unavailable` error
# (never a fake heuristic). Swap to Copyleaks via a new PlagiarismVendor adapter.
ORIGINALITY_API_KEY=
