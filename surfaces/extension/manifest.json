{
  "manifest_version": 3,
  "name": "Help Me Write Better",
  "version": "1.0.0",
  "description": "Improve and format text in any tab — preserving meaning and voice.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Help Me Write Better",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "permissions": ["contextMenus", "storage", "scripting", "activeTab"],
  "host_permissions": ["http://localhost/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
