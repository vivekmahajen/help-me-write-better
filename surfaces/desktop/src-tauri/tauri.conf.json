{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Help Me Write Better",
  "version": "1.0.0",
  "identifier": "com.helpmewritebetter.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Help Me Write Better",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
